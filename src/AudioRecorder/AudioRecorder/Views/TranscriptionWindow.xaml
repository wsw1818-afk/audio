<Window x:Class="AudioRecorder.Views.TranscriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="녹취록 변환"
        Width="700" Height="650"
        MinWidth="550" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#0D1117"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- 색상 정의 -->
        <SolidColorBrush x:Key="BgBrush" Color="#0D1117"/>
        <SolidColorBrush x:Key="CardBrush" Color="#161B22"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#21262D"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFB347"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SubTextBrush" Color="#8B949E"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#30363D"/>

        <!-- 콤보박스 아이템 스타일 -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- 체크박스 스타일 -->
        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <!-- 버튼 스타일 -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#FFB347"/>
            <Setter Property="Foreground" Value="#0D1117"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFC97A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#30363D"/>
                                <Setter Property="Foreground" Value="#8B949E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubButton" TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#30363D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#484F58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="📝 녹취록 변환" FontSize="20" FontWeight="Bold" Foreground="#FFB347"/>
            <TextBlock x:Name="FileNameText" Text="" FontSize="13" Foreground="#8B949E" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 설정 영역 -->
        <Border Grid.Row="1" Background="#161B22" CornerRadius="8" Padding="16" Margin="0,0,0,12"
                BorderBrush="#30363D" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 모델 표시 -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                    <TextBlock Text="모델" Foreground="#8B949E" FontSize="12" Margin="0,0,0,4"/>
                    <Border Background="#21262D" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4" Padding="8,6">
                        <TextBlock Text="Large-v3-turbo (1.6GB, 고정확+고속)" Foreground="#FFB347" FontSize="13" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <!-- 언어 선택 -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                    <TextBlock Text="언어" Foreground="#8B949E" FontSize="12" Margin="0,0,0,4"/>
                    <ComboBox x:Name="LanguageCombo" Style="{StaticResource DarkComboBox}">
                        <ComboBoxItem Content="자동 감지" IsSelected="True" Tag="auto"/>
                        <ComboBoxItem Content="한국어" Tag="ko"/>
                        <ComboBoxItem Content="영어" Tag="en"/>
                        <ComboBoxItem Content="일본어" Tag="ja"/>
                        <ComboBoxItem Content="중국어" Tag="zh"/>
                    </ComboBox>
                </StackPanel>

                <!-- 최대 화자 수 -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                    <TextBlock Text="최대 화자 수" Foreground="#8B949E" FontSize="12" Margin="0,0,0,4"/>
                    <ComboBox x:Name="MaxSpeakersCombo" Style="{StaticResource DarkComboBox}">
                        <ComboBoxItem Content="2명"/>
                        <ComboBoxItem Content="3명"/>
                        <ComboBoxItem Content="4명" IsSelected="True"/>
                        <ComboBoxItem Content="6명"/>
                        <ComboBoxItem Content="8명"/>
                    </ComboBox>
                </StackPanel>

                <!-- 옵션 체크박스 -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,0">
                    <CheckBox x:Name="DiarizationCheck" Content="화자 분리" IsChecked="True"
                              Style="{StaticResource DarkCheckBox}" Margin="0,0,20,0"/>
                    <CheckBox x:Name="WordTimestampCheck" Content="단어별 타임스탬프" IsChecked="True"
                              Style="{StaticResource DarkCheckBox}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 변환 버튼 + 진행률 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="TranscribeButton" Content="▶ 변환 시작"
                        Style="{StaticResource AccentButton}"
                        Click="TranscribeButton_Click" HorizontalAlignment="Stretch"/>
                <Button x:Name="CancelButton" Content="취소" Grid.Column="1"
                        Style="{StaticResource SubButton}" Margin="8,0,0,0"
                        Click="CancelButton_Click" Visibility="Collapsed"/>
            </Grid>

            <!-- 진행률 바 -->
            <Grid x:Name="ProgressPanel" Margin="0,8,0,0" Visibility="Collapsed">
                <ProgressBar x:Name="ProgressBar" Height="6" Background="#21262D"
                             Foreground="#FFB347" BorderThickness="0" Minimum="0" Maximum="100"/>
            </Grid>
            <TextBlock x:Name="StatusText" Text="" Foreground="#8B949E" FontSize="12"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 결과 영역 -->
        <Border Grid.Row="3" Background="#161B22" CornerRadius="8" Padding="12"
                BorderBrush="#30363D" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 결과 헤더 -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="📋 결과" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="ResultInfoText" Text="" Foreground="#8B949E" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                    </StackPanel>
                </Grid>

                <!-- 결과 텍스트 -->
                <TextBox x:Name="ResultTextBox" Grid.Row="1"
                         Background="#0D1117" Foreground="White" FontSize="13"
                         BorderBrush="#30363D" BorderThickness="1"
                         Padding="10" IsReadOnly="True"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Malgun Gothic, Segoe UI"
                         Text="변환 결과가 여기에 표시됩니다..."/>
            </Grid>
        </Border>

        <!-- 하단 버튼 -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="CopyButton" Content="📋 복사" Grid.Column="0"
                    Style="{StaticResource SubButton}" Click="CopyButton_Click"
                    IsEnabled="False" Margin="0,0,8,0"/>
            <Button x:Name="ExportTxtButton" Content="💾 TXT" Grid.Column="1"
                    Style="{StaticResource SubButton}" Click="ExportTxtButton_Click"
                    IsEnabled="False" Margin="0,0,8,0"/>
            <Button x:Name="ExportSrtButton" Content="💾 SRT" Grid.Column="2"
                    Style="{StaticResource SubButton}" Click="ExportSrtButton_Click"
                    IsEnabled="False" Margin="0,0,8,0"/>

            <Button Content="닫기" Grid.Column="4" Style="{StaticResource SubButton}"
                    Click="CloseButton_Click"/>
        </Grid>
    </Grid>
</Window>
