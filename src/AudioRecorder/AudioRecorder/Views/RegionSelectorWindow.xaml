<Window x:Class="AudioRecorder.Views.RegionSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="영역 선택"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowState="Maximized"
        ShowInTaskbar="False"
        Cursor="Cross">

    <Grid>
        <!-- 반투명 오버레이 -->
        <Canvas x:Name="OverlayCanvas" Background="#44000000">
            <!-- 선택 영역은 코드에서 동적으로 추가 -->
        </Canvas>

        <!-- 안내 텍스트 -->
        <Border Background="#CC000000"
                CornerRadius="8"
                Padding="20,10"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="마우스로 드래그하여 녹화 영역을 선택하세요. "
                           Foreground="White"
                           FontSize="14"/>
                <TextBlock Text="ESC"
                           Foreground="#4CAF50"
                           FontWeight="Bold"
                           FontSize="14"/>
                <TextBlock Text="를 눌러 취소"
                           Foreground="White"
                           FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- 선택 영역 크기 표시 -->
        <Border x:Name="SizeIndicator"
                Background="#CC000000"
                CornerRadius="4"
                Padding="10,5"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Visibility="Collapsed">
            <TextBlock x:Name="SizeText"
                       Foreground="White"
                       FontSize="12"/>
        </Border>
    </Grid>
</Window>
