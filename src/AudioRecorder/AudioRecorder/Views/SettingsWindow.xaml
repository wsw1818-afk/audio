<Window x:Class="AudioRecorder.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Width="560" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}">

    <Border Margin="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="⚙ 설정" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextColor}"/>
                <TextBlock Text="녹음/녹화 옵션을 조정합니다."
                           FontSize="11" Foreground="{StaticResource SubTextColor}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 탭 컨트롤 (스타일은 FluentDarkTheme.xaml의 기본 TabControl/TabItem 사용) -->
            <TabControl Grid.Row="1">

                <!-- 오디오 -->
                <TabItem Header="오디오">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16"
                                  Background="{StaticResource BackgroundColor}">
                        <StackPanel>
                            <TextBlock Text="녹음 소스" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextColor}" Margin="0,0,0,8"/>
                            <CheckBox Content="마이크 녹음" IsChecked="{Binding RecordMicrophone}" Margin="0,4"/>
                            <CheckBox Content="시스템 사운드 녹음" IsChecked="{Binding RecordSystemAudio}" Margin="0,4,0,12"/>

                            <TextBlock Text="마이크 볼륨" FontSize="12"
                                       Foreground="{StaticResource SubTextColor}" Margin="0,0,0,4"/>
                            <Slider Value="{Binding MicVolume}" Minimum="0" Maximum="1"
                                    TickFrequency="0.1" Margin="0,0,0,12"/>

                            <TextBlock Text="시스템 볼륨" FontSize="12"
                                       Foreground="{StaticResource SubTextColor}" Margin="0,0,0,4"/>
                            <Slider Value="{Binding SystemVolume}" Minimum="0" Maximum="1"
                                    TickFrequency="0.1" Margin="0,0,0,12"/>

                            <TextBlock Text="저장 포맷" FontSize="12"
                                       Foreground="{StaticResource SubTextColor}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding AvailableFormats}"
                                      SelectedItem="{Binding SelectedRecordingFormat}"
                                      Margin="0,0,0,12"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- 화면 녹화 -->
                <TabItem Header="화면 녹화">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16"
                                  Background="{StaticResource BackgroundColor}">
                        <StackPanel>
                            <TextBlock Text="녹화 영역" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextColor}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding CaptureRegionText}" FontSize="12"
                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>

                            <TextBlock Text="화질" FontSize="12"
                                       Foreground="{StaticResource SubTextColor}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding VideoQualityOptions}"
                                      SelectedItem="{Binding SelectedVideoQuality}"
                                      Margin="0,0,0,12"/>

                            <TextBlock Text="해상도" FontSize="12"
                                       Foreground="{StaticResource SubTextColor}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding ResolutionOptions}"
                                      SelectedItem="{Binding SelectedResolution}"
                                      Margin="0,0,0,12"/>

                            <CheckBox Content="마우스 커서 표시" IsChecked="{Binding ShowMouseCursor}" Margin="0,4"/>
                            <CheckBox Content="클릭 시 하이라이트" IsChecked="{Binding HighlightMouseClicks}" Margin="0,4"/>
                            <CheckBox Content="녹화 영역 테두리 표시" IsChecked="{Binding ShowRecordingBorder}" Margin="0,4,0,12"/>

                            <TextBlock Text="카운트다운 (초)" FontSize="12"
                                       Foreground="{StaticResource SubTextColor}" Margin="0,0,0,4"/>
                            <Slider Value="{Binding CountdownSeconds}" Minimum="0" Maximum="10"
                                    TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,12"/>

                            <TextBlock Text="영상 오디오 비트레이트" FontSize="12"
                                       Foreground="{StaticResource SubTextColor}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding AudioBitrateOptions}"
                                      SelectedItem="{Binding SelectedAudioBitrate}"
                                      Margin="0,0,0,12"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- 일반 -->
                <TabItem Header="일반">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16"
                                  Background="{StaticResource BackgroundColor}">
                        <StackPanel>
                            <TextBlock Text="저장 폴더" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextColor}" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding OutputDirectory}" IsReadOnly="True"
                                         Background="{StaticResource SurfaceColor}"
                                         Foreground="{StaticResource TextColor}"
                                         BorderBrush="{StaticResource BorderColor}"
                                         Padding="8,6"/>
                                <Button Grid.Column="1" Content="변경" Margin="8,0,0,0" Padding="16,6"
                                        Command="{Binding BrowseOutputDirectoryCommand}"/>
                            </Grid>

                            <TextBlock Text="창 닫기 동작" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextColor}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding CloseActionOptions}"
                                      SelectedItem="{Binding SelectedCloseActionText}"
                                      Margin="0,0,0,12"/>

                            <TextBlock Text="자동 영상 압축" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextColor}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding VideoCompressionOptions}"
                                      SelectedItem="{Binding SelectedVideoCompressionText}"
                                      Margin="0,0,0,12"/>

                            <TextBlock Text="워터마크" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextColor}" Margin="8,8,0,4"/>
                            <TextBox Text="{Binding WatermarkText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{StaticResource SurfaceColor}"
                                     Foreground="{StaticResource TextColor}"
                                     BorderBrush="{StaticResource BorderColor}"
                                     Padding="8,6"
                                     ToolTip="화면 녹화에 표시할 텍스트 (비워두면 없음)"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- 하단 버튼 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="닫기" Width="80" Height="32" Click="CloseButton_Click"
                        Background="{StaticResource AccentBrush}"
                        Foreground="{StaticResource BackgroundColor}"
                        FontWeight="SemiBold" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
