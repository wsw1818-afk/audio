<Window x:Class="AudioRecorder.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AudioRecorder.ViewModels"
        xmlns:conv="clr-namespace:AudioRecorder.Converters"
        mc:Ignorable="d"
        Title="AudioRecorder Pro"
        Height="600" Width="900"
        MinHeight="500" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- 색상 정의 - 모던 다크 테마 -->
        <Color x:Key="AccentColor">#FFB347</Color>
        <Color x:Key="AccentDarkColor">#E09422</Color>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>
        <SolidColorBrush x:Key="PrimaryColor" Color="#4CAF50"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#2196F3"/>
        <SolidColorBrush x:Key="DangerColor" Color="#FF5252"/>
        <SolidColorBrush x:Key="WarningColor" Color="#FFB347"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#0D1117"/>
        <SolidColorBrush x:Key="CardColor" Color="#161B22"/>
        <SolidColorBrush x:Key="SurfaceColor" Color="#21262D"/>
        <SolidColorBrush x:Key="TextColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SubTextColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#30363D"/>

        <!-- 사이드바 버튼 스타일 -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource SubTextColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 컨트롤 버튼 스타일 -->
        <Style x:Key="ControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="25">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 파일 아이템 버튼 스타일 -->
        <Style x:Key="FileItemButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 윈도우 컨트롤 버튼 -->
        <Style x:Key="WindowButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource SubTextColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 모던 슬라이더 스타일 -->
        <Style x:Key="ModernSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Background="#333" CornerRadius="3" Height="6"/>
                            <Border Background="{StaticResource AccentBrush}"
                                    CornerRadius="3" Height="6"
                                    HorizontalAlignment="Left"
                                    Width="{TemplateBinding Value}"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Ellipse Fill="{StaticResource AccentBrush}"
                                                         Width="14" Height="14"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 모던 콤보박스 스타일 -->
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{StaticResource SurfaceColor}"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      TextBlock.Foreground="#FFFFFF"/>
                                    <TextBlock Grid.Column="1" Text="▼" FontSize="8"
                                               Foreground="#FFFFFF"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="false"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"/>
                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   Placement="Bottom">
                                <Border Background="{StaticResource CardColor}"
                                        BorderBrush="{StaticResource BorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,2,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="200">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 콤보박스 아이템 스타일 -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceColor}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceColor}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceColor}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 기본 콤보박스 스타일 (설정 패널용) -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{StaticResource SurfaceColor}"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      TextBlock.Foreground="#FFFFFF"/>
                                    <TextBlock Grid.Column="1" Text="▼" FontSize="8"
                                               Foreground="#FFFFFF"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="false"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"/>
                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   Placement="Bottom">
                                <Border Background="{StaticResource CardColor}"
                                        BorderBrush="{StaticResource BorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,2,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="200">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 체크박스 스타일 -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="CheckBorder"
                                    Width="18" Height="18"
                                    Background="{StaticResource SurfaceColor}"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Margin="0,0,8,0">
                                <TextBlock x:Name="CheckMark" Text="✓"
                                           FontSize="13"
                                           Foreground="{StaticResource PrimaryColor}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource SubTextColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 메인 컨테이너 -->
    <Border Background="{StaticResource BackgroundColor}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측 사이드바 -->
            <Border Grid.Column="0" Background="{StaticResource CardColor}"
                    CornerRadius="12,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 로고 -->
                    <TextBlock Grid.Row="0" Text="🎙️" FontSize="24"
                               HorizontalAlignment="Center" Margin="0,20,0,30"/>

                    <!-- 녹화 모드 선택 -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center">
                        <!-- 오디오 녹음 모드 -->
                        <Button ToolTip="오디오 녹음 모드"
                                Click="AudioModeButton_Click"
                                IsEnabled="{Binding CanSwitchModeBinding}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                    <Setter Property="Content" Value="🎙️"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAudioOnlyMode}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
                                            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- 화면 녹화 모드 -->
                        <Button ToolTip="화면 녹화 모드"
                                Click="ScreenModeButton_Click"
                                IsEnabled="{Binding CanSwitchModeBinding}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                    <Setter Property="Content" Value="🖥️"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScreenRecordingMode}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
                                            <Setter Property="Foreground" Value="{StaticResource DangerColor}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Separator Background="{StaticResource BorderColor}" Height="1" Margin="5,10"/>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Content="📁" ToolTip="출력 폴더 열기"
                                Command="{Binding OpenOutputDirectoryCommand}"/>
                    </StackPanel>

                    <!-- 하단 설정 -->
                    <Button Grid.Row="2" Style="{StaticResource SidebarButtonStyle}"
                            Content="⚙️" ToolTip="설정"
                            Command="{Binding ToggleOptionsCommand}"
                            Margin="0,0,0,20"/>
                </Grid>
            </Border>

            <!-- 메인 콘텐츠 영역 -->
            <Grid Grid.Column="1" Margin="30,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 타이틀바 -->
                <Grid Grid.Row="0">
                    <TextBlock Text="AudioRecorder Pro"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource SubTextColor}"
                               VerticalAlignment="Center"/>

                    <!-- 윈도우 컨트롤 -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource WindowButtonStyle}"
                                Content="─" Click="MinimizeButton_Click"/>
                        <Button Style="{StaticResource WindowButtonStyle}"
                                Content="□" Click="MaximizeButton_Click"/>
                        <Button Style="{StaticResource WindowButtonStyle}"
                                Content="✕" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>

                <!-- 중앙 비주얼 영역 -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 메인 비주얼 - 웨이브폼/레벨 미터 -->
                    <Border Grid.Row="0" Background="{StaticResource CardColor}"
                            CornerRadius="16" Margin="0,10">
                        <Grid>
                            <!-- 배경 그라데이션 -->
                            <Border CornerRadius="16">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1a1a2e" Offset="0"/>
                                        <GradientStop Color="#16213e" Offset="0.5"/>
                                        <GradientStop Color="#0f3460" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <!-- 타이머 -->
                                <TextBlock Text="{Binding ElapsedTime}"
                                           FontSize="72"
                                           FontWeight="Light"
                                           FontFamily="Segoe UI"
                                           Foreground="{StaticResource TextColor}"
                                           HorizontalAlignment="Center"/>

                                <!-- 상태 텍스트 -->
                                <TextBlock Text="{Binding StatusText}"
                                           FontSize="16"
                                           Foreground="{StaticResource SubTextColor}"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,30"/>

                                <!-- 레벨 미터 바 (웨이브폼 스타일) -->
                                <Grid Width="400" Height="60" Margin="0,20,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 마이크 레벨 -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="🎤 마이크" FontSize="11"
                                                   Foreground="{StaticResource SubTextColor}"
                                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <Border Background="#1a1a2e" CornerRadius="4" Height="30">
                                            <Border Background="{StaticResource PrimaryColor}"
                                                    CornerRadius="4"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding MicLevel, Converter={StaticResource LevelToWidthConverter}}"/>
                                        </Border>
                                        <TextBlock Text="{Binding MicLevelDb}" FontSize="10"
                                                   Foreground="{StaticResource SubTextColor}"
                                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- 시스템 레벨 -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="🔊 시스템" FontSize="11"
                                                   Foreground="{StaticResource SubTextColor}"
                                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <Border Background="#1a1a2e" CornerRadius="4" Height="30">
                                            <Border Background="{StaticResource AccentBrush}"
                                                    CornerRadius="4"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding SystemLevel, Converter={StaticResource LevelToWidthConverter}}"/>
                                        </Border>
                                        <TextBlock Text="{Binding SystemLevelDb}" FontSize="10"
                                                   Foreground="{StaticResource SubTextColor}"
                                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 파일 정보 -->
                    <TextBlock Grid.Row="1" Text="{Binding FileInfo}"
                               FontSize="13"
                               Foreground="{StaticResource SubTextColor}"
                               HorizontalAlignment="Center"
                               Margin="0,5"/>

                    <!-- 하단 컨트롤 바 -->
                    <Border Grid.Row="2" Background="{StaticResource CardColor}"
                            CornerRadius="12" Padding="15,12" Margin="0,10,0,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 상단: 컨트롤 버튼 -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal"
                                        HorizontalAlignment="Center" Margin="0,0,0,10">
                                <!-- 녹음 시작 버튼 -->
                                <Button x:Name="StartRecordingButton"
                                        Click="StartRecordingButton_Click"
                                        Background="{StaticResource DangerColor}"
                                        ToolTip="녹음 시작 (Ctrl+R)">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ControlButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RecordingState}" Value="Recording">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RecordingState}" Value="Paused">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="⏺" FontSize="24"/>
                                </Button>

                                <!-- 일시정지/재개 버튼 -->
                                <Button Command="{Binding PauseRecordingCommand}"
                                        ToolTip="일시정지 (Ctrl+P)">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ControlButtonStyle}">
                                            <Setter Property="Background" Value="{StaticResource WarningColor}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RecordingState}" Value="Paused">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RecordingState}" Value="Stopped">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="⏸" FontSize="24"/>
                                </Button>

                                <Button Command="{Binding ResumeRecordingCommand}"
                                        ToolTip="재개">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ControlButtonStyle}">
                                            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RecordingState}" Value="Paused">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="▶" FontSize="24"/>
                                </Button>

                                <!-- 정지 버튼 -->
                                <Button Style="{StaticResource ControlButtonStyle}"
                                        Command="{Binding StopRecordingCommand}"
                                        Background="{StaticResource SurfaceColor}"
                                        ToolTip="정지 (Ctrl+S)">
                                    <TextBlock Text="⏹" FontSize="24"/>
                                </Button>
                            </StackPanel>

                            <!-- 하단: 옵션 (왼쪽: 오디오 소스, 오른쪽: 모드별 옵션) -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 왼쪽 - 오디오 소스 선택 -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <CheckBox Content="마이크" IsChecked="{Binding RecordMicrophone}"
                                              Margin="0,0,15,0"/>
                                    <CheckBox Content="시스템" IsChecked="{Binding RecordSystemAudio}"/>
                                </StackPanel>

                                <!-- 오른쪽 - 모드별 옵션 -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <!-- 오디오 녹음 모드 옵션 -->
                                    <StackPanel x:Name="AudioOptionsPanel" Orientation="Horizontal"
                                                Visibility="{Binding IsAudioOnlyMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="포맷:" FontSize="13"
                                                   Foreground="{StaticResource TextColor}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox ItemsSource="{Binding AvailableFormats}"
                                                  SelectedItem="{Binding SelectedRecordingFormat}"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="140" Height="30" FontSize="13">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource FormatToDisplayNameConverter}}"
                                                               Foreground="#FFFFFF"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- 화면 녹화 모드 옵션 -->
                                    <StackPanel x:Name="ScreenOptionsPanel" Orientation="Horizontal"
                                                Visibility="{Binding IsScreenRecordingMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <!-- 녹화 대상 선택 -->
                                        <TextBlock Text="대상:" FontSize="13"
                                                   Foreground="{StaticResource TextColor}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="CaptureTargetCombo" Width="110" Height="30"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  SelectedIndex="0" Margin="0,0,15,0" FontSize="13"
                                                  ToolTip="녹화 대상 선택"
                                                  SelectionChanged="CaptureTargetCombo_SelectionChanged">
                                            <ComboBoxItem Content="전체 화면" Tag="FullScreen"/>
                                            <ComboBoxItem Content="모니터" Tag="Monitor"/>
                                            <ComboBoxItem Content="창" Tag="Window"/>
                                            <ComboBoxItem Content="영역" Tag="Region"/>
                                        </ComboBox>
                                        <!-- 품질 선택 -->
                                        <TextBlock Text="품질:" FontSize="13"
                                                   Foreground="{StaticResource TextColor}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox ItemsSource="{Binding VideoQualityOptions}"
                                                  SelectedItem="{Binding SelectedVideoQuality}"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="90" Height="30" FontSize="13"
                                                  ToolTip="최고 화질: 60fps, 고화질: 30fps"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 우측 패널 - 최근 파일 & 설정 -->
            <Border Grid.Column="2" Background="{StaticResource CardColor}"
                    CornerRadius="0,12,12,0" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 헤더 -->
                    <TextBlock Grid.Row="0" Text="{Binding RecentFilesHeader}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextColor}"
                               Margin="0,10,0,15"/>

                    <!-- 재생 컨트롤 (재생 중일 때) -->
                    <Border Grid.Row="1" Background="{StaticResource SurfaceColor}"
                            CornerRadius="10" Padding="12" Margin="0,0,0,10"
                            Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding PlaybackTime}"
                                       Foreground="{StaticResource TextColor}"
                                       FontSize="12" HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <Slider Value="{Binding PlaybackPosition}"
                                    Maximum="{Binding PlaybackDuration}"
                                    Minimum="0" Height="6" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Style="{StaticResource FileItemButtonStyle}"
                                        Content="⏸"
                                        Command="{Binding PausePlaybackCommand}"
                                        Background="{StaticResource WarningColor}"/>
                                <Button Style="{StaticResource FileItemButtonStyle}"
                                        Content="⏹"
                                        Command="{Binding StopPlaybackCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 파일 목록 -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FilteredRecentFiles, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SurfaceColor}"
                                            CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 파일명 -->
                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding FileName, Mode=OneWay}"
                                                       Foreground="{StaticResource TextColor}"
                                                       FontSize="12" FontWeight="Medium"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <!-- 파일 정보 -->
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding FileDetails, Mode=OneWay}"
                                                       Foreground="{StaticResource SubTextColor}"
                                                       FontSize="10"
                                                       Margin="0,4,0,8"/>

                                            <!-- 버튼들 -->
                                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                                <Button Style="{StaticResource FileItemButtonStyle}"
                                                        Content="▶" ToolTip="재생"
                                                        Background="{StaticResource SecondaryColor}"
                                                        Command="{Binding DataContext.PlayFileCommand,
                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Style="{StaticResource FileItemButtonStyle}"
                                                        Content="📁" ToolTip="탐색기"
                                                        Command="{Binding DataContext.OpenInExplorerCommand,
                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                                <!-- 압축 버튼 (동영상만) -->
                                                <Button Style="{StaticResource FileItemButtonStyle}"
                                                        Content="📦" ToolTip="H.265 압축"
                                                        Background="#FF6B5B"
                                                        Click="CompressButton_Click"
                                                        Tag="{Binding}"
                                                        Visibility="{Binding IsVideo, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="최고 품질로 압축 (H.265)"
                                                                      Command="{Binding DataContext.CompressVideoHighCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            <MenuItem Header="보통 품질로 압축 (H.265, 용량↓)"
                                                                      Command="{Binding DataContext.CompressVideoNormalCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                </Button>
                                                <Button Style="{StaticResource FileItemButtonStyle}"
                                                        Content="📝" ToolTip="녹취록 변환"
                                                        Background="#20B2AA"
                                                        Command="{Binding DataContext.OpenTranscriptionCommand,
                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Style="{StaticResource FileItemButtonStyle}"
                                                        Content="🗑" ToolTip="삭제"
                                                        Background="{StaticResource DangerColor}"
                                                        Command="{Binding DataContext.DeleteRecordingCommand,
                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 빈 상태 -->
                    <TextBlock Grid.Row="2" Text="{Binding EmptyFilesMessage}"
                               Foreground="{StaticResource SubTextColor}"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasNoFilteredFiles}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- 옵션 패널 오버레이 -->
            <Border Grid.Column="1" Grid.ColumnSpan="2"
                    Background="#E0000000"
                    CornerRadius="0,12,12,0"
                    Visibility="{Binding IsOptionsExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                    MouseDown="OptionsOverlay_MouseDown">
                <Border Background="{StaticResource CardColor}"
                        CornerRadius="12"
                        Width="500" MaxHeight="550"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="25"
                        MouseDown="OptionsPanel_MouseDown">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 헤더 -->
                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock Text="⚙️ 설정" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextColor}"/>
                            <Button HorizontalAlignment="Right"
                                    Style="{StaticResource WindowButtonStyle}"
                                    Content="✕" FontSize="16"
                                    Width="36" Height="36"
                                    Command="{Binding ToggleOptionsCommand}"
                                    ToolTip="닫기"/>
                        </Grid>

                        <!-- 설정 내용 (스크롤 가능) -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- 장치 선택 -->
                                <TextBlock Text="🎧 장치 선택" FontSize="13" FontWeight="Medium"
                                           Foreground="{StaticResource TextColor}" Margin="0,0,0,8"/>

                                <TextBlock Text="마이크" FontSize="11"
                                           Foreground="{StaticResource SubTextColor}" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding InputDevices}"
                                          SelectedItem="{Binding SelectedInputDevice}"
                                          DisplayMemberPath="FriendlyName"
                                          Margin="0,0,0,8"/>

                                <TextBlock Text="시스템 출력" FontSize="11"
                                           Foreground="{StaticResource SubTextColor}" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding OutputDevices}"
                                          SelectedItem="{Binding SelectedOutputDevice}"
                                          DisplayMemberPath="FriendlyName"
                                          Margin="0,0,0,8"/>

                                <Button Content="🔄 장치 새로고침"
                                        Command="{Binding RefreshDevicesCommand}"
                                        HorizontalAlignment="Left"
                                        Padding="8,4"
                                        Background="Transparent"
                                        Foreground="{StaticResource SecondaryColor}"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Margin="0,0,0,15"/>

                                <!-- 저장 경로 -->
                                <TextBlock Text="📁 저장 경로" FontSize="13" FontWeight="Medium"
                                           Foreground="{StaticResource TextColor}" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding OutputDirectory}"
                                             IsReadOnly="True"
                                             Background="{StaticResource SurfaceColor}"
                                             Foreground="{StaticResource TextColor}"
                                             BorderThickness="0"
                                             Padding="8,6"
                                             FontSize="10"/>
                                    <Button Grid.Column="1"
                                            Content="📁"
                                            Command="{Binding BrowseOutputDirectoryCommand}"
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Width="32" Height="32"/>
                                </Grid>

                                <!-- 일반 설정 -->
                                <TextBlock Text="⚙️ 일반" FontSize="13" FontWeight="Medium"
                                           Foreground="{StaticResource TextColor}" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="창 닫을 때:" FontSize="12"
                                               Foreground="{StaticResource SubTextColor}"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ComboBox ItemsSource="{Binding CloseActionOptions}"
                                              SelectedItem="{Binding SelectedCloseActionText}"
                                              Width="150" FontSize="12"/>
                                </StackPanel>

                                <!-- 자동 분할 녹음 (오디오 모드일 때만 표시) -->
                                <StackPanel Visibility="{Binding IsAudioOnlyMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="✂️ 자동 분할" FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource TextColor}" Margin="0,0,0,8"/>

                                    <CheckBox Content="자동 분할 녹음"
                                              IsChecked="{Binding AutoSplitEnabled}"
                                              Foreground="{StaticResource TextColor}"
                                              Margin="0,0,0,8"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15"
                                                IsEnabled="{Binding AutoSplitEnabled}">
                                        <TextBlock Text="분할 간격:" FontSize="11"
                                                   Foreground="{StaticResource SubTextColor}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox ItemsSource="{Binding AutoSplitIntervalOptions}"
                                                  SelectedItem="{Binding AutoSplitIntervalMinutes}"
                                                  Width="70" FontSize="11"/>
                                        <TextBlock Text="분" FontSize="11"
                                                   Foreground="{StaticResource SubTextColor}"
                                                   VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- 화면 녹화 옵션 (화면 녹화 모드일 때만 표시) -->
                                <StackPanel Visibility="{Binding IsScreenRecordingMode, Converter={StaticResource BoolToVisibilityConverter}}">

                                    <!-- 녹화 옵션 -->
                                    <TextBlock Text="🎬 녹화 옵션" FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource TextColor}" Margin="0,0,0,8"/>

                                    <CheckBox Content="마우스 클릭 강조"
                                              IsChecked="{Binding HighlightMouseClicks}"
                                              Foreground="{StaticResource TextColor}"
                                              Margin="0,0,0,5"/>

                                    <CheckBox Content="녹화 영역 테두리 표시"
                                              IsChecked="{Binding ShowRecordingBorder}"
                                              Foreground="{StaticResource TextColor}"
                                              Margin="0,0,0,8"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="자동 압축:" FontSize="11"
                                                   Foreground="{StaticResource SubTextColor}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox ItemsSource="{Binding VideoCompressionOptions}"
                                                  SelectedItem="{Binding SelectedVideoCompressionText}"
                                                  Width="160" FontSize="11"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <TextBlock Text="카운트다운:" FontSize="11"
                                                   Foreground="{StaticResource SubTextColor}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox ItemsSource="{Binding CountdownOptions}"
                                                  SelectedItem="{Binding CountdownSeconds}"
                                                  Width="60" FontSize="11"/>
                                        <TextBlock Text="초" FontSize="11"
                                                   Foreground="{StaticResource SubTextColor}"
                                                   VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </StackPanel>

                                    <!-- 출력 설정 -->
                                    <TextBlock Text="📹 출력 설정" FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource TextColor}" Margin="0,0,0,8"/>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                            <TextBlock Text="해상도" FontSize="11"
                                                       Foreground="{StaticResource SubTextColor}" Margin="0,0,0,4"/>
                                            <ComboBox ItemsSource="{Binding ResolutionOptions}"
                                                      SelectedItem="{Binding SelectedResolution}"
                                                      FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                            <TextBlock Text="오디오 품질" FontSize="11"
                                                       Foreground="{StaticResource SubTextColor}" Margin="0,0,0,4"/>
                                            <ComboBox ItemsSource="{Binding AudioBitrateOptions}"
                                                      SelectedItem="{Binding SelectedAudioBitrate}"
                                                      FontSize="11"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- 웹캠 오버레이 -->
                                    <TextBlock Text="📷 웹캠 오버레이" FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource TextColor}" Margin="0,10,0,8"/>

                                    <CheckBox Content="웹캠 표시"
                                              IsChecked="{Binding EnableWebcamOverlay}"
                                              Foreground="{StaticResource TextColor}"
                                              Margin="0,0,0,8"/>

                                    <Grid Margin="0,0,0,8"
                                          IsEnabled="{Binding EnableWebcamOverlay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                            <TextBlock Text="위치" FontSize="11"
                                                       Foreground="{StaticResource SubTextColor}" Margin="0,0,0,4"/>
                                            <ComboBox ItemsSource="{Binding PositionOptions}"
                                                      SelectedItem="{Binding SelectedWebcamPosition}"
                                                      FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                            <TextBlock Text="크기" FontSize="11"
                                                       Foreground="{StaticResource SubTextColor}" Margin="0,0,0,4"/>
                                            <ComboBox ItemsSource="{Binding WebcamSizeOptions}"
                                                      SelectedItem="{Binding SelectedWebcamSize}"
                                                      FontSize="11"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- 워터마크 -->
                                    <TextBlock Text="💧 워터마크" FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource TextColor}" Margin="0,10,0,8"/>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding WatermarkText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="{StaticResource SurfaceColor}"
                                                 Foreground="{StaticResource TextColor}"
                                                 BorderThickness="0"
                                                 Padding="8,6"
                                                 FontSize="11"
                                                 Margin="0,0,5,0"/>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding PositionOptions}"
                                                  SelectedItem="{Binding SelectedWatermarkPosition}"
                                                  FontSize="11"/>
                                    </Grid>

                                    <!-- 예약 녹화 -->
                                    <TextBlock Text="⏰ 예약 녹화" FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource TextColor}" Margin="0,10,0,8"/>

                                    <CheckBox Content="예약 녹화 사용"
                                              IsChecked="{Binding EnableScheduledRecording}"
                                              Foreground="{StaticResource TextColor}"
                                              Margin="0,0,0,8"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                                IsEnabled="{Binding EnableScheduledRecording}">
                                        <TextBlock Text="녹화 시간:" FontSize="11"
                                                   Foreground="{StaticResource SubTextColor}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Text="{Binding ScheduledDurationMinutes}"
                                                 Width="50"
                                                 Background="{StaticResource SurfaceColor}"
                                                 Foreground="{StaticResource TextColor}"
                                                 BorderThickness="0"
                                                 Padding="6,4"
                                                 FontSize="11"/>
                                        <TextBlock Text="분" FontSize="11"
                                                   Foreground="{StaticResource SubTextColor}"
                                                   VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- 하단 닫기 버튼 -->
                        <Button Grid.Row="2" Content="닫기"
                                Command="{Binding ToggleOptionsCommand}"
                                HorizontalAlignment="Center"
                                Padding="30,10"
                                Margin="0,15,0,0"
                                FontSize="14"
                                Background="{StaticResource SurfaceColor}"
                                Foreground="{StaticResource TextColor}"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BorderColor}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
