<Window x:Class="AudioRecorder.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AudioRecorder.ViewModels"
        xmlns:conv="clr-namespace:AudioRecorder.Converters"
        mc:Ignorable="d"
        Title="AudioRecorder Pro"
        Height="540" Width="900"
        MinHeight="460" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <!-- 테마 리소스는 App.xaml의 Themes/FluentDarkTheme.xaml에서 제공 -->
    <Window.Resources/>

    <!-- D1 Arc Glass — Mica 레이어드 배경 + 글래스 카드 -->
    <Border CornerRadius="14" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
        <Grid>
            <!-- 베이스 다크 그라디언트 -->
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0.0" Color="#141020"/>
                    <GradientStop Offset="0.5" Color="#0F0F18"/>
                    <GradientStop Offset="1.0" Color="#10161E"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Mica 오브: 좌상단 마젠타 -->
            <Rectangle IsHitTestVisible="False">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.22,0.28" GradientOrigin="0.22,0.28" RadiusX="0.45" RadiusY="0.5">
                        <GradientStop Offset="0.0" Color="#55B52B87"/>
                        <GradientStop Offset="1.0" Color="#00B52B87"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <!-- Mica 오브: 우하단 시안 -->
            <Rectangle IsHitTestVisible="False">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.82,0.78" GradientOrigin="0.82,0.78" RadiusX="0.42" RadiusY="0.48">
                        <GradientStop Offset="0.0" Color="#452B7FB5"/>
                        <GradientStop Offset="1.0" Color="#002B7FB5"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <!-- Mica 오브: 중앙 레드 글로우 -->
            <Rectangle IsHitTestVisible="False">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.45,0.32" GradientOrigin="0.45,0.32" RadiusX="0.25" RadiusY="0.3">
                        <GradientStop Offset="0.0" Color="#35FF453A"/>
                        <GradientStop Offset="1.0" Color="#00FF453A"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- 콘텐츠 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ============ TITLEBAR ============ -->
                <Border Grid.Row="0" Grid.ColumnSpan="2" Background="Transparent">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                            <TextBlock Text="🎙" FontSize="14" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="AudioRecorder Pro v1.2.1" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextColor}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource WindowButtonStyle}" Content="─" Click="MinimizeButton_Click"/>
                            <Button Style="{StaticResource WindowButtonStyle}" Content="▢" Click="MaximizeButton_Click"/>
                            <Button Style="{StaticResource WindowButtonStyle}" Content="✕" Click="CloseButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ============ LEFT SIDEBAR — 네비게이션 전용 (모드 전환은 우측 카드 담당) ============ -->
                <Border Grid.Row="1" Grid.Column="0" Background="Transparent">
                    <Grid>
                        <!-- 상단: 네비게이션 -->
                        <StackPanel VerticalAlignment="Top" Margin="0,6,0,0">
                            <Button Style="{StaticResource SidebarButtonStyle}" Content="🏠" ToolTip="홈 (현재)"/>
                            <Button Style="{StaticResource SidebarButtonStyle}" Content="📂"
                                    Command="{Binding OpenOutputDirectoryCommand}" ToolTip="출력 폴더"/>
                            <Button Style="{StaticResource SidebarButtonStyle}" Content="🔄"
                                    Command="{Binding RefreshDevicesCommand}" ToolTip="장치 새로고침"/>
                        </StackPanel>
                        <!-- 하단: 설정 -->
                        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,12">
                            <Button Style="{StaticResource SidebarButtonStyle}" Content="⚙"
                                    Click="SettingsButton_Click" ToolTip="설정"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ============ MAIN CONTENT ============ -->
                <Grid Grid.Row="1" Grid.Column="1" Margin="12,4,18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ============ HERO (Left) ============ -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="8,8,24,0">
                        <TextBlock Text="오늘," FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextColor}" Margin="0,0,0,2"/>
                        <!-- 오디오 모드: "녹음할까요?" / 화면 모드: "녹화할까요?" -->
                        <TextBlock FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextColor}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="무엇을 녹음할까요?"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScreenRecordingMode}" Value="True">
                                            <Setter Property="Text" Value="무엇을 녹화할까요?"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource SubTextColor}"
                                   Margin="0,8,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="고음질로 모든 순간을 기록하세요."/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScreenRecordingMode}" Value="True">
                                            <Setter Property="Text" Value="화면과 소리를 함께 녹화하세요."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- ============ 녹음/녹화 컨트롤 (Left, row 1) ============ -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="8,20,24,0"
                                HorizontalAlignment="Left" Orientation="Horizontal">
                        <!-- 시작 버튼 (정지 상태에서만 보임) -->
                        <Button Style="{StaticResource RecordPillButtonStyle}"
                                Command="{Binding StartRecordingCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="12" Height="12" Fill="{StaticResource TextColor}" Margin="0,0,12,0"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="녹음 시작" VerticalAlignment="Center"
                                           Visibility="{Binding IsAudioOnlyMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBlock Text="녹화 시작" VerticalAlignment="Center"
                                           Visibility="{Binding IsScreenRecordingMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Button>
                        <!-- 일시정지 (녹음 중에만 활성) -->
                        <Button Style="{StaticResource GlassIconButtonStyle}"
                                Content="⏸" ToolTip="일시정지" Margin="12,0,0,0"
                                Command="{Binding PauseRecordingCommand}"/>
                        <!-- 정지 -->
                        <Button Style="{StaticResource GlassIconButtonStyle}"
                                Content="⏹" ToolTip="정지" Margin="8,0,0,0"
                                Command="{Binding StopRecordingCommand}"/>
                        <!-- 경과 시간 -->
                        <TextBlock Text="{Binding ElapsedTime}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextColor}" VerticalAlignment="Center"
                                   Margin="18,0,0,0" FontFamily="{StaticResource MonoFont}"/>
                    </StackPanel>

                    <!-- ============ 모드 카드 (Right, rows 0-1 spanned) — 모드 전환 단일 책임 ============ -->
                    <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Margin="0,16,0,0">
                        <!-- 선택된 모드는 앰버 테두리 -->
                        <Button Command="{Binding SwitchToAudioModeCommand}"
                                Click="AudioModeButton_Click"
                                ToolTip="오디오 모드로 전환"
                                Padding="20,16"
                                HorizontalContentAlignment="Left"
                                Foreground="{StaticResource TextColor}"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModeCardButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAudioOnlyMode}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                            <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="🎙" FontSize="22" VerticalAlignment="Center"/>
                                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="오디오 모드" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextColor}"/>
                                        <TextBlock Text="마이크 또는 시스템 사운드 녹음" FontSize="11"
                                                   Foreground="{StaticResource SubTextColor}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- 현재 모드 체크 표시 -->
                                <TextBlock Grid.Column="1" Text="●" FontSize="14"
                                           Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                           Visibility="{Binding IsAudioOnlyMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </Button>
                        <Button Command="{Binding SwitchToScreenModeCommand}"
                                Click="ScreenModeButton_Click"
                                Margin="0,10,0,0"
                                IsEnabled="{Binding IsScreenRecordingAvailable}"
                                Padding="20,16"
                                HorizontalContentAlignment="Left"
                                Foreground="{StaticResource TextColor}"
                                Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="ToolTip">
                                    <Setter Property="Placement" Value="Top"/>
                                </Style>
                            </Button.Resources>
                            <Button.ToolTip>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="화면 녹화 모드로 전환"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsScreenRecordingAvailable}" Value="False">
                                                    <Setter Property="Text" Value="FFmpeg가 필요합니다. ffmpeg.exe를 앱 폴더에 복사하세요."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button.ToolTip>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModeCardButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScreenRecordingMode}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                            <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="🖥" FontSize="22" VerticalAlignment="Center"/>
                                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="화면 모드" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextColor}"/>
                                        <TextBlock Text="화면과 소리를 함께 녹음" FontSize="11"
                                                   Foreground="{StaticResource SubTextColor}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="●" FontSize="14"
                                           Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                           Visibility="{Binding IsScreenRecordingMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <!-- ============ 최근 녹음 LIST (rows 2 span all cols) ============ -->
                    <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="8,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="{Binding RecentFilesHeader}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextColor}"/>
                            <TextBlock Text="모두 보기 ›" FontSize="12"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
                            <ItemsControl ItemsSource="{Binding FilteredRecentFiles, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource GlassListItemStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="200"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- 재생 버튼 -->
                                                <Button Grid.Column="0" Style="{StaticResource GlassIconButtonStyle}"
                                                        Width="36" Height="36" Content="▶"
                                                        Foreground="{StaticResource AccentBrush}"
                                                        Command="{Binding DataContext.PlayFileCommand,
                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                                <!-- 파일명 -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextColor}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <!-- 파일 세부정보 (날짜 | 시간 | 크기) -->
                                                <TextBlock Grid.Column="2" Text="{Binding FileDetails, Mode=OneWay}" FontSize="11"
                                                           Foreground="{StaticResource SubTextColor}"
                                                           VerticalAlignment="Center" HorizontalAlignment="Right"
                                                           Margin="16,0" TextTrimming="CharacterEllipsis"/>
                                                <!-- 빈 컬럼 (예전 시간 자리) -->
                                                <TextBlock Grid.Column="3" Text="" Margin="0"/>
                                                <!-- 더보기 -->
                                                <StackPanel Grid.Column="4" Orientation="Horizontal">
                                                    <Button Style="{StaticResource GlassIconButtonStyle}"
                                                            Width="32" Height="32" Content="📁" ToolTip="폴더에서 열기"
                                                            Command="{Binding DataContext.OpenInExplorerCommand,
                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Style="{StaticResource GlassIconButtonStyle}"
                                                            Width="32" Height="32" Content="🗑" ToolTip="삭제"
                                                            Margin="4,0,0,0"
                                                            Command="{Binding DataContext.DeleteRecordingCommand,
                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- ============ BOTTOM DEVICE BAR (오디오 모드) ============ -->
                <Border Grid.Row="2" Grid.Column="1" Margin="12,10,18,14" Padding="14,10"
                        Background="{StaticResource GlassCardBrush}"
                        BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="14"
                        Visibility="{Binding IsAudioOnlyMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- 마이크 -->
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding InputDevices}"
                                  SelectedItem="{Binding SelectedInputDevice}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  ToolTip="마이크 선택"
                                  Margin="0,0,8,0"/>
                        <!-- 시스템 사운드 -->
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding OutputDevices}"
                                  SelectedItem="{Binding SelectedOutputDevice}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  ToolTip="시스템 사운드 선택"
                                  Margin="0,0,12,0"/>
                        <!-- 포맷 콤보 -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <ComboBox Width="120"
                                      ItemsSource="{Binding AvailableFormats}"
                                      SelectedItem="{Binding SelectedRecordingFormat}"
                                      Style="{StaticResource ModernComboBoxStyle}"
                                      ToolTip="저장 포맷"/>
                            <Button Style="{StaticResource GlassIconButtonStyle}"
                                    Content="📁" ToolTip="저장 폴더 열기"
                                    Command="{Binding OpenOutputDirectoryCommand}"
                                    Margin="6,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ============ BOTTOM SCREEN BAR (화면 모드) ============ -->
                <Border Grid.Row="2" Grid.Column="1" Margin="12,10,18,14" Padding="14,10"
                        Background="{StaticResource GlassCardBrush}"
                        BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="14"
                        Visibility="{Binding IsScreenRecordingMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- 영역 라벨 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0,12,0">
                            <TextBlock Text="영역:" FontSize="12"
                                       Foreground="{StaticResource SubTextColor}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CaptureRegionText}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextColor}" VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                        <!-- 영역 선택 버튼 4개 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource DevicePillButtonStyle}" MinWidth="76" Height="32"
                                    Content="🖥 전체" ToolTip="전체 화면"
                                    Command="{Binding SelectFullScreenCommand}"/>
                            <Button Style="{StaticResource DevicePillButtonStyle}" MinWidth="80" Height="32"
                                    Content="🖼 모니터" ToolTip="특정 모니터 선택"
                                    Margin="6,0,0,0"
                                    Command="{Binding SelectMonitorCommand}"/>
                            <Button Style="{StaticResource DevicePillButtonStyle}" MinWidth="72" Height="32"
                                    Content="🪟 창" ToolTip="특정 창 선택"
                                    Margin="6,0,0,0"
                                    Command="{Binding SelectWindowCommand}"/>
                            <Button Style="{StaticResource DevicePillButtonStyle}" MinWidth="76" Height="32"
                                    Content="✂ 영역" ToolTip="영역 드래그 선택"
                                    Margin="6,0,0,0"
                                    Command="{Binding SelectRegionCommand}"/>
                        </StackPanel>
                        <!-- 화질 콤보 -->
                        <ComboBox Grid.Column="2" Width="110"
                                  ItemsSource="{Binding VideoQualityOptions}"
                                  SelectedItem="{Binding SelectedVideoQuality}"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  ToolTip="화질"
                                  Margin="12,0,8,0"/>
                        <!-- 폴더 -->
                        <Button Grid.Column="3" Style="{StaticResource GlassIconButtonStyle}"
                                Content="📁" ToolTip="저장 폴더 열기"
                                Command="{Binding OpenOutputDirectoryCommand}"/>
                    </Grid>
                </Border>

                <!-- 상태 텍스트 (좌측 하단) -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding StatusText}"
                           FontSize="10" Foreground="{StaticResource SubTextColor}"
                           VerticalAlignment="Bottom" HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
            </Grid>
        </Grid>
    </Border>
</Window>
