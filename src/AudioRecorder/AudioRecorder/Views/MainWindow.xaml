<Window x:Class="AudioRecorder.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AudioRecorder.ViewModels"
        mc:Ignorable="d"
        Title="AudioRecorder Pro"
        Height="850" Width="550"
        MinHeight="750" MinWidth="450"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- 색상 정의 -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#4CAF50"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#2196F3"/>
        <SolidColorBrush x:Key="DangerColor" Color="#F44336"/>
        <SolidColorBrush x:Key="WarningColor" Color="#FF9800"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="CardColor" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="TextColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SubTextColor" Color="#AAAAAA"/>

        <!-- 버튼 스타일 -->
        <Style x:Key="RecordButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="70"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource CardColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="35"
                                BorderThickness="2"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 카드 스타일 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardColor}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <!-- 체크박스 스타일 -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>

        <!-- 콤보박스 스타일 -->
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <!-- 슬라이더 스타일 -->
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 타이틀 -->
        <TextBlock Grid.Row="0"
                   Text="🎙️ AudioRecorder Pro"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextColor}"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,10"/>

        <!-- 타이머 표시 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="20,5">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding ElapsedTime}"
                           FontSize="48"
                           FontWeight="Bold"
                           FontFamily="Consolas"
                           Foreground="{StaticResource TextColor}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding StatusText}"
                           FontSize="14"
                           Foreground="{StaticResource SubTextColor}"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- 레벨 미터 -->
        <Grid Grid.Row="2" Margin="20,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 마이크 레벨 -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="🎤 마이크" FontSize="14" Foreground="{StaticResource TextColor}"/>
                        <TextBlock Text="{Binding MicLevelDb}" FontSize="12"
                                   Foreground="{StaticResource SubTextColor}" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- 레벨 바 -->
                    <Border Background="#333" CornerRadius="3" Height="20" x:Name="MicLevelContainer">
                        <Border Background="{StaticResource PrimaryColor}"
                                CornerRadius="3"
                                HorizontalAlignment="Left"
                                Width="{Binding MicLevel, Converter={StaticResource LevelToWidthConverter}}"/>
                    </Border>

                    <!-- 볼륨 조절 -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="볼륨:" Foreground="{StaticResource SubTextColor}"
                                   VerticalAlignment="Center" Width="40"/>
                        <Slider Value="{Binding MicVolume}"
                                Minimum="0" Maximum="1" Width="100"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding MicVolume, StringFormat={}{0:P0}}"
                                   Foreground="{StaticResource SubTextColor}"
                                   VerticalAlignment="Center" Width="40" Margin="5,0,0,0"/>
                    </StackPanel>

                    <!-- 포함 체크 -->
                    <CheckBox Content="녹음 포함" IsChecked="{Binding RecordMicrophone}" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- 시스템 오디오 레벨 -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="🔊 시스템" FontSize="14" Foreground="{StaticResource TextColor}"/>
                        <TextBlock Text="{Binding SystemLevelDb}" FontSize="12"
                                   Foreground="{StaticResource SubTextColor}" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- 레벨 바 -->
                    <Border Background="#333" CornerRadius="3" Height="20">
                        <Border Background="{StaticResource SecondaryColor}"
                                CornerRadius="3"
                                HorizontalAlignment="Left"
                                Width="{Binding SystemLevel, Converter={StaticResource LevelToWidthConverter}}"/>
                    </Border>

                    <!-- 볼륨 조절 -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="볼륨:" Foreground="{StaticResource SubTextColor}"
                                   VerticalAlignment="Center" Width="40"/>
                        <Slider Value="{Binding SystemVolume}"
                                Minimum="0" Maximum="1" Width="100"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SystemVolume, StringFormat={}{0:P0}}"
                                   Foreground="{StaticResource SubTextColor}"
                                   VerticalAlignment="Center" Width="40" Margin="5,0,0,0"/>
                    </StackPanel>

                    <!-- 포함 체크 -->
                    <CheckBox Content="녹음 포함" IsChecked="{Binding RecordSystemAudio}" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 장치 선택 -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="20,5">
            <StackPanel>
                <TextBlock Text="장치 선택" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource TextColor}" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="마이크:"
                               Foreground="{StaticResource SubTextColor}"
                               VerticalAlignment="Center" Margin="0,0,10,5"/>
                    <ComboBox Grid.Row="0" Grid.Column="1"
                              ItemsSource="{Binding InputDevices}"
                              SelectedItem="{Binding SelectedInputDevice}"
                              DisplayMemberPath="FriendlyName"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="출력:"
                               Foreground="{StaticResource SubTextColor}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox Grid.Row="1" Grid.Column="1"
                              ItemsSource="{Binding OutputDevices}"
                              SelectedItem="{Binding SelectedOutputDevice}"
                              DisplayMemberPath="FriendlyName"/>
                </Grid>

                <Button Content="🔄 장치 새로고침"
                        Command="{Binding RefreshDevicesCommand}"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0"
                        Padding="10,5"
                        Background="Transparent"
                        Foreground="{StaticResource SecondaryColor}"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- 녹음 컨트롤 버튼 -->
        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Margin="20,5">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <!-- 녹음 시작 버튼 -->
                    <Button Style="{StaticResource RecordButtonStyle}"
                            Command="{Binding StartRecordingCommand}"
                            Background="{StaticResource DangerColor}"
                            ToolTip="녹음 시작">
                        <TextBlock Text="⏺" FontSize="28"/>
                    </Button>

                    <!-- 일시정지 버튼 -->
                    <Button Command="{Binding PauseRecordingCommand}"
                            ToolTip="일시정지">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RecordButtonStyle}">
                                <Setter Property="Background" Value="{StaticResource WarningColor}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecordingState}" Value="Paused">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RecordingState}" Value="Stopped">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="⏸" FontSize="28"/>
                    </Button>

                    <!-- 재개 버튼 -->
                    <Button Command="{Binding ResumeRecordingCommand}"
                            ToolTip="재개">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RecordButtonStyle}">
                                <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecordingState}" Value="Paused">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="▶" FontSize="28"/>
                    </Button>

                    <!-- 정지 버튼 -->
                    <Button Style="{StaticResource RecordButtonStyle}"
                            Command="{Binding StopRecordingCommand}"
                            Background="#555"
                            ToolTip="정지">
                        <TextBlock Text="⏹" FontSize="28"/>
                    </Button>
                </StackPanel>

                <!-- 저장 경로 -->
                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <TextBlock Text="저장 경로:" Foreground="{StaticResource SubTextColor}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Text="{Binding OutputDirectory}"
                             Width="280" IsReadOnly="True"
                             Background="#333" Foreground="{StaticResource TextColor}"
                             BorderThickness="0" Padding="5"/>
                    <Button Content="📁" Command="{Binding BrowseOutputDirectoryCommand}"
                            Margin="5,0" Padding="8,3"
                            Background="Transparent" Foreground="{StaticResource TextColor}"
                            BorderThickness="0" Cursor="Hand" ToolTip="폴더 선택"/>
                    <Button Content="📂" Command="{Binding OpenOutputDirectoryCommand}"
                            Padding="8,3"
                            Background="Transparent" Foreground="{StaticResource TextColor}"
                            BorderThickness="0" Cursor="Hand" ToolTip="폴더 열기"/>
                </StackPanel>

                <TextBlock Text="{Binding FileInfo}"
                           Foreground="{StaticResource SubTextColor}"
                           FontSize="12" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- 최근 파일 목록 -->
        <Border Grid.Row="5" Style="{StaticResource CardStyle}" Margin="20,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="📂 최근 녹음 파일" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource TextColor}" Margin="0,0,0,10"/>

                <!-- 재생 컨트롤 (재생 중일 때만 표시) -->
                <Border Grid.Row="1" Background="#252525" CornerRadius="5" Padding="10" Margin="0,0,0,10"
                        Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="{Binding PlaybackTime}" Foreground="{StaticResource TextColor}"
                                   FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <Slider Value="{Binding PlaybackPosition}" Maximum="{Binding PlaybackDuration}"
                                Minimum="0" Height="20"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                            <Button Content="⏸" Command="{Binding PausePlaybackCommand}"
                                    Width="40" Height="30" Margin="5,0"
                                    Background="{StaticResource WarningColor}" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" ToolTip="일시정지/재개"/>
                            <Button Content="⏹" Command="{Binding StopPlaybackCommand}"
                                    Width="40" Height="30" Margin="5,0"
                                    Background="#555" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" ToolTip="정지"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="2" MaxHeight="180" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding RecentFiles, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#333" CornerRadius="5" Padding="10,8" Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding FileName, Mode=OneWay}"
                                                       Foreground="White" FontSize="12"/>
                                            <TextBlock Text="{Binding FileDetails, Mode=OneWay}"
                                                       Foreground="#888" FontSize="10"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="▶" ToolTip="내장 재생"
                                                    Command="{Binding DataContext.PlayFileCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Width="30" Height="26" Margin="2,0"
                                                    Background="{StaticResource SecondaryColor}"
                                                    Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                            <Button Content="🔊" ToolTip="기본 앱으로 열기"
                                                    Command="{Binding DataContext.PlayWithDefaultAppCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Width="30" Height="26" Margin="2,0"
                                                    Background="#555" Foreground="White"
                                                    BorderThickness="0" Cursor="Hand"/>
                                            <Button Content="📁" ToolTip="탐색기에서 열기"
                                                    Command="{Binding DataContext.OpenInExplorerCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Width="30" Height="26" Margin="2,0"
                                                    Background="#555" Foreground="White"
                                                    BorderThickness="0" Cursor="Hand"/>
                                            <Button Content="🎵" ToolTip="MP3로 변환 (FFmpeg 필요)"
                                                    Command="{Binding DataContext.ConvertToMp3AsyncCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Width="30" Height="26" Margin="2,0"
                                                    Background="#9C27B0" Foreground="White"
                                                    BorderThickness="0" Cursor="Hand"/>
                                            <Button Content="🗑" ToolTip="삭제"
                                                    Command="{Binding DataContext.DeleteRecordingCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Width="30" Height="26" Margin="2,0"
                                                    Background="{StaticResource DangerColor}"
                                                    Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Grid.Row="3" Text="녹음 파일이 없습니다"
                           Foreground="{StaticResource SubTextColor}"
                           HorizontalAlignment="Center"
                           Margin="0,20">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RecentFiles.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- 하단 상태바 -->
        <Border Grid.Row="6" Background="#252525" Padding="15,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           Foreground="{StaticResource SubTextColor}" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="Ctrl+R 녹음 | Ctrl+P 일시정지 | Ctrl+S 정지"
                           Foreground="#666" FontSize="10" Margin="0,0,15,0"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="WAV 48kHz/16bit/Stereo"
                           Foreground="{StaticResource SubTextColor}" FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>
