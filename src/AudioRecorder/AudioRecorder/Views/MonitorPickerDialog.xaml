<Window x:Class="AudioRecorder.Views.MonitorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="모니터 선택"
        Width="600"
        Height="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="녹화할 모니터를 선택하세요"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="SemiBold"/>
            <TextBlock Text="연결된 모니터 목록입니다"
                       Foreground="#AAAAAA"
                       FontSize="12"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- 모니터 목록 -->
        <Border Grid.Row="1"
                Background="#2D2D2D"
                CornerRadius="8"
                BorderBrush="#3D3D3D"
                BorderThickness="1">
            <ListBox x:Name="MonitorList"
                     Background="Transparent"
                     BorderThickness="0"
                     SelectionMode="Single"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="MonitorList_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="15"/>
                        <Setter Property="Margin" Value="5"/>
                        <Setter Property="Background" Value="#3D3D3D"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="#4D4D4D"
                                            BorderThickness="1"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="8">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#4CAF50"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#66BB6A"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#4D4D4D"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsSelected" Value="True"/>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Bd" Property="Background" Value="#66BB6A"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 모니터 아이콘 -->
                            <Border Grid.Column="0"
                                    Background="#2D2D2D"
                                    CornerRadius="6"
                                    Padding="10"
                                    Margin="0,0,15,0">
                                <TextBlock Text="🖥️" FontSize="24"/>
                            </Border>

                            <!-- 모니터 정보 -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock Text="{Binding Resolution}"
                                           FontSize="12"
                                           Foreground="#AAAAAA"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding Position}"
                                           FontSize="11"
                                           Foreground="#888888"
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Primary 표시 -->
                            <Border Grid.Column="2"
                                    Background="#FFB347"
                                    CornerRadius="4"
                                    Padding="8,4"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsPrimaryVisibility}">
                                <TextBlock Text="기본" FontSize="11" Foreground="#1E1E1E" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- 버튼 -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button x:Name="CancelButton"
                    Content="취소"
                    Width="80"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"
                    Background="#3D3D3D"
                    Foreground="White"
                    BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button x:Name="SelectButton"
                    Content="선택"
                    Width="80"
                    Height="32"
                    Click="SelectButton_Click"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    IsDefault="True">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
